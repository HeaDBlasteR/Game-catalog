{
  "name": "game-catalog",
  "version": "1.0.0",
  "description": "",
  "main": "dist-electron/electron/main.js",
  "scripts": {
  "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
  "dev:renderer": "vite",
  "dev:electron": "tsc -p tsconfig.electron.json && cross-env NODE_ENV=development electron .",
  "build": "npm run build:renderer && npm run build:electron",
  "build:renderer": "vite build",
  "build:electron": "tsc -p tsconfig.electron.json",
  "start": "cross-env NODE_ENV=production electron dist-electron/main.js",
  "postinstall": "electron-rebuild"
  },
  "keywords": [],
  "author": "Artyom",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/bcrypt": "^6.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sqlite3": "^3.1.11",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
